[init]
	defaultBranch = main
[include]
	path = .gitconfig_env
[core]
	# Disable pagination for all commands by default
	pager = cat
	# Default editor
	editor = vim
	excludesfile = ~/.gitignore_global
[alias]
	# Pure shortcuts
	br = branch
	ci = commit
	co = checkout
	df = diff
	dfc = diff --cached
	s = status
	rem = remote
	# push origin main
	pom = push origin main
	# pull (mnemonic="get") origin main
	gom = pull origin main
	# push proxy work
	ppw = push proxy work
	# pull (mnemonic="get") proxy work
	gpw = pull proxy work
	# Show branches verbosely
	brv = branch -vvv
	remv = remote -vvv
	# Create a new branch and check it out
	cob = checkout -b
	# Delete a branch
	del = checkout -D
	# Show status in short format with branch info
	st = status -sb
        # Rebase from the remote
        pr2 = pull --rebase
	# Rebase from the remote and autostash unstaged changes.
	# This stashes changes, does the rebase, then applies the stashed
	# changes.
        pr = pull --rebase --autostash
	# Unstage files
	unstage = reset HEAD --
	# List git aliases
	alias = config --get-regexp ^alias\\.
	# Various ways of showing repo history
	hist = log --pretty=tformat:\"%h %ad | %s%d [%an]\" --graph --date=short
	lg = log --graph --pretty=tformat:'%h -%d %s (%cr) <%an>' \
		--abbrev-commit --date=relative
	one = log --oneline
	# Last N commits on a given file.
	# Runs a small shell function and parses its args.
	lastn = "!f(){ n=\"$1\"; file=\"$2\"; shift 2; \
		git one -n \"$n\" --follow -- \"$file\" \"$@\"; }; f"
	lastnv = "!f(){ n=\"$1\"; file=\"$2\"; shift 2; \
		git log -n \"$n\" --follow -- \"$file\" \"$@\"; }; f"
	histn = "!f(){ n=\"$1\"; file=\"$2\"; shift 2; \
		git hist -n \"$n\" --follow -- \"$file\" \"$@\"; }; f"
	lgn = "!f(){ n=\"$1\"; file=\"$2\"; shift 2; \
		git lg -n \"$n\" --follow -- \"$file\" \"$@\"; }; f"
	last = log -1 HEAD
	# Upstream delta commands
	log-up = log --oneline --decorate --graph @{u}..HEAD --
	logv-up = log --decorate --abbrev-commit --stat @{u}..HEAD --
	diff-up = diff @{u}..HEAD
	files-up = diff --name-status @{u}..HEAD
[pull]
	# Equivalent of --ff-only option
	ff = only
