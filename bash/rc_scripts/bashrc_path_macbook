# shellcheck shell=bash
# vim: syntax=sh
# vim: filetype=sh

# Macbook-specific PATH setup
# Called from .bashrc

TEX_DIR="/Library/TeX/texbin"
if [ -d "$TEX_DIR" ]; then
    export PATH=$PATH:$TEX_DIR
fi

# Add Visual Studio Code (code)
VSCODE_DIR="/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
if [ -d "$VSCODE_DIR" ]; then
    export PATH="$PATH:$VSCODE_DIR"
fi

RUST_ENV="$HOME/.cargo/env"
if test -f "$RUST_ENV"; then
    # shellcheck disable=SC1090
    . "$RUST_ENV"
fi

export PATH=/usr/local/bin:$PATH
export PATH=/usr/local/sbin:$PATH
if [ "$BREW_PATH" != "/usr/local" ]; then
    export PATH=$BREW_PATH/bin:$PATH
    export PATH=$BREW_PATH/sbin:$PATH
fi

if command -v brew &> /dev/null; then
    # Put this before /usr/bin/ so python defaults to python3
    PYTHON_DIR=$(brew --prefix python)/libexec/bin
    if [ -d "$PYTHON_DIR" ]; then
        export PATH=$PYTHON_DIR:$PATH
    fi
fi
